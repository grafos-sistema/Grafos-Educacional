# ==========================================
# ENVIRONMENT VARIABLES
# ==========================================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Manter apenas os exemplos
!.env.example
!.env.prod

# ==========================================
# NODE MODULES
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================
# BUILD & DIST
# ==========================================
dist/
build/
out/
.next/
.turbo/
*.tsbuildinfo

# ==========================================
# LOGS
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pids
*.pid
*.pid.lock

# ==========================================
# UPLOADS & MEDIA
# ==========================================
uploads/
public/uploads/
temp/
tmp/

# ==========================================
# BACKUPS
# ==========================================
backups/*.sql
backups/*.sql.gz
*.dump
*.backup

# Manter diretório de backups mas não os arquivos
!backups/.gitkeep

# ==========================================
# COVERAGE & TESTS
# ==========================================
coverage/
*.lcov
.nyc_output
.cache
test-results/
playwright-report/
junit.xml

# ==========================================
# DATABASE
# ==========================================
*.sqlite
*.sqlite3
*.db

# Prisma
**/prisma/.env
prisma/migrations/**/*.sql
!prisma/migrations/migration_lock.toml

# ==========================================
# DOCKER
# ==========================================
# Manter os Dockerfiles e docker-compose, mas ignorar alguns temporários
docker-compose.override.yml
.dockerignore.bak

# ==========================================
# IDEs & EDITORS
# ==========================================
# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains (WebStorm, IntelliJ, etc)
.idea/
*.iml
*.iws
.idea_modules/

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ==========================================
