# ==========================================
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
ssl/
certs/
certificates/

# ==========================================
# MISC
# ==========================================
# Temporary files
*.tmp
*.temp
*.swp
*.swo
*.bak
*.orig

# Lock files (exceto package-lock.json e yarn.lock que devem ser versionados)
# package-lock.json e yarn.lock SÃO versionados para garantir dependências
# Mas se preferir não versionar, descomente:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Next.js
.next/
out/

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# PWA files
**/public/sw.js
**/public/workbox-*.js
**/public/worker-*.js
**/public/sw.js.map
**/public/workbox-*.js.map
**/public/worker-*.js.map

# ==========================================
# PROJECT SPECIFIC
# ==========================================
# Prisma generated files (são regenerados)
**/generated/

# Logs da aplicação
api/logs/
frontend/logs/

# Uploads de produção
api/uploads/*
!api/uploads/.gitkeep

# Cache
.cache/
*.cache

# Storybook
.storybook-static/

# ==========================================
# CI/CD
# ==========================================
.github/workflows/*.log

# ==========================================
# MISC FRAMEWORKS
# ==========================================
# ESLint
.eslintcache

# Prettier
.prettierignore

# Stylelint
.stylelintcache

# ==========================================
# SECURITY
# ==========================================
# Nunca versionar arquivos com secrets ou credenciais
secrets.yaml
secrets.json
credentials.json
serviceAccount.json
firebase-adminsdk-*.json
